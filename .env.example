# Flask
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_PATH=/data/archivesmap.db

# Admin credentials
ADMIN_EMAIL=admin@archivesmap.org
ADMIN_USERNAME=admin
# Generate with:  flask hash-password yourpassword
ADMIN_PASSWORD_HASH=

# Email (SMTP)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=Archives World Map <noreply@archivesmap.org>

# reCAPTCHA v3  (https://www.google.com/recaptcha/admin)
# Leave blank to disable captcha (development only)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_THRESHOLD=0.5

# Public base URL — used in email approve/reject links
BASE_URL=https://www.archivesmap.org
